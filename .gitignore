# Environments / caches
.venv/
__pycache__/
*.pyc

# Local review archive — not for sharing
_archive/
# NOTE: uv.lock is intentionally NOT ignored — commit it to pin extra versions.

# Large CRAG data — CC BY-NC 4.0, fetch separately (see docs/STUDY.md); never commit.
# Place downloads in data/. Also covers the regenerable fixture (experiments/make_fixture.py).
*.jsonl.bz2

# Scratch outputs — all runs write to results/ by default; ignore root-level strays.
/stabilization.csv
/latency_validation.csv
/stabilization.summary.json
/phi_distribution.png

# LaTeX build intermediates (keep main.tex / results.tex / refs.bib + main.pdf)
paper/*.aux
paper/*.log
paper/*.bbl
paper/*.blg
paper/*.out
paper/*.fdb_latexmk
paper/*.fls
paper/*.synctex.gz
